from pydantic import BaseModel

class Address(BaseModel):
    city:str
    state:str
    pin:str

class patient(BaseModel):
    name:str
    age:int
    height:float
    weight:float
    address:Address


address_dcit={'city': "Mumbai", 'state': "Maharashtra", 'pin': "400001"}
address1=Address(**address_dcit)
patient_info={'name': "John Doe", 'age': 30, 'height': 175.0, 'weight': 70.5, 'address': address1}
patient1=patient(**patient_info)
print(patient1)
